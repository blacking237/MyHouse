# MyHOUSE placeholder environment variables (do not commit real secrets).
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080

# Backend database
DB_URL=jdbc:postgresql://localhost:5432/myhouse
DB_USERNAME=myhouse
DB_PASSWORD=myhouse

# Security
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
JWT_ACCESS_SECONDS=900
JWT_REFRESH_SECONDS=2592000

# Flutterwave
FLUTTERWAVE_ENABLED=false
FLUTTERWAVE_PUBLIC_KEY=YOUR_FLUTTERWAVE_PUBLIC_KEY
FLUTTERWAVE_SECRET_KEY=YOUR_FLUTTERWAVE_SECRET_KEY

# WhatsApp Business
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=YOUR_WHATSAPP_TOKEN
WHATSAPP_PHONE_ID=YOUR_WHATSAPP_PHONE_ID

# SendGrid
SENDGRID_ENABLED=false
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
SENDGRID_FROM=no-reply@myhouse.local

# Expo push
EXPO_PUSH_ENABLED=false
EXPO_PUSH_TOKEN=YOUR_EXPO_PUSH_TOKEN
