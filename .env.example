# MyHouse placeholder environment variables for Vercel + Render + Neon.

# Public frontend URLs
EXPO_PUBLIC_API_BASE_URL=https://myhouse-api.onrender.com
APP_WEB_URL=https://myhouse.vercel.app
APP_API_URL=https://myhouse-api.onrender.com
APP_CORS_ALLOWED_ORIGINS=https://myhouse.vercel.app

# Backend runtime
SPRING_PROFILES_ACTIVE=production
PORT=8080
RESET_DEFAULT_ADMIN_ON_STARTUP=false

# Neon PostgreSQL
DB_URL=jdbc:postgresql://ep-example-region.neon.tech/neondb?sslmode=require
DB_USERNAME=neondb_owner
DB_PASSWORD=CHANGE_ME
DB_DRIVER=org.postgresql.Driver

# Security
JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
JWT_ACCESS_SECONDS=900
JWT_REFRESH_SECONDS=2592000
RECOVERY_ADMIN_CODE=CHANGE_ME
RECOVERY_CODE_TTL_MINUTES=15

# SMTP
RECOVERY_MAIL_ENABLED=true
RECOVERY_MAIL_FROM=no-reply@myhouse.app
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true

# Flutterwave
FLUTTERWAVE_ENABLED=false
FLUTTERWAVE_PUBLIC_KEY=YOUR_FLUTTERWAVE_PUBLIC_KEY
FLUTTERWAVE_SECRET_KEY=YOUR_FLUTTERWAVE_SECRET_KEY

# WhatsApp Business
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=YOUR_WHATSAPP_TOKEN
WHATSAPP_PHONE_ID=YOUR_WHATSAPP_PHONE_ID

# SendGrid
SENDGRID_ENABLED=false
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY
SENDGRID_FROM=no-reply@myhouse.app

# Expo push
EXPO_PUSH_ENABLED=false
EXPO_PUSH_TOKEN=YOUR_EXPO_PUSH_TOKEN
