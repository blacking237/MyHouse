{
  "name": "myhouse",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:release": "powershell -ExecutionPolicy Bypass -File .\\scripts\\build-android-release.ps1",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:prod": "expo export --platform web",
    "desktop:dev": "npm --prefix .\\desktop-shell run dev",
    "desktop:remote": "npm --prefix .\\desktop-shell run dev:remote",
    "desktop:local": "npm --prefix .\\desktop-shell run dev:local",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "^14.0.0",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-contacts": "~14.0.2",
    "expo-crypto": "~14.0.0",
    "expo-file-system": "~18.0.0",
    "expo-font": "~13.0.4",
    "expo-linking": "~7.0.0",
    "expo-sharing": "~13.0.0",
    "expo-sqlite": "~15.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.6",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-safe-area-context": "4.14.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "typescript": "^5.3.0"
  },
  "private": true
}
